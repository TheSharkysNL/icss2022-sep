LinkColor := #ff0000;
ParWidth := 500px;
UseLinkColor := FALSE;
A := !UseLinkColor;

p {
	background-color: #ffffff;
	width: ParWidth;
	if[ParWidth > 100px] {
	    color: #124532;
	    if[UseLinkColor]{
	        background-color: LinkColor;
	    } else {
	        background-color: #000000;
	    }
	}
	height: 20px;
}
a {
	color: LinkColor;
}

#menu {
	width: ParWidth + 20px;
}

.menu {
	color: #000000;
    background-color: LinkColor;

}
